{
  "name": "mist-mcp-provider",
  "displayName": "Mist MCP Provider",
  "description": "Provides a preconfigured Mist MCP server for VS Code.",
  "icon": "media/icon.png",
  "version": "0.2.0",
  "publisher": "tmunzer",
  "repository": {
    "type": "git",
    "url": "https://github.com/tmunzer-AIDE/mist-mcp-vsix.git"
  },
  "bugs": {
    "url": "https://github.com/tmunzer-AIDE/mist-mcp-vsix/issues"
  },
  "homepage": "https://github.com/tmunzer-AIDE/mist-mcp-vsix#readme",
  "keywords": [
    "mcp",
    "mist",
    "juniper",
    "copilot",
    "ai"
  ],
  "license": "MIT",
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mistMcpProvider.configure",
        "title": "Mist MCP: Add or Update Profile"
      },
      {
        "command": "mistMcpProvider.selectProfile",
        "title": "Mist MCP: Select Active Profile"
      },
      {
        "command": "mistMcpProvider.editProfile",
        "title": "Mist MCP: Edit Profile"
      },
      {
        "command": "mistMcpProvider.deleteProfile",
        "title": "Mist MCP: Delete Profile"
      },
      {
        "command": "mistMcpProvider.renameProfile",
        "title": "Mist MCP: Rename Profile"
      },
      {
        "command": "mistMcpProvider.clearToken",
        "title": "Mist MCP: Clear Active Profile Token"
      }
    ],
    "mcpServerDefinitionProviders": [
      {
        "id": "mist.mcp.provider",
        "label": "Mist MCP Server Provider"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test out/test/**/*.test.js",
    "package": "vsce package --allow-missing-repository"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "@types/vscode": "^1.105.0",
    "@vscode/vsce": "^3.3.2",
    "typescript": "^5.8.3"
  }
}
